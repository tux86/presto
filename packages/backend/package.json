{
  "name": "@presto/backend",
  "version": "1.23.3",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --env-file ../../.env --hot src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun --define __APP_VERSION__='\"'$npm_package_version'\"'",
    "db:generate": "bun run --env-file ../../.env drizzle-kit generate",
    "db:migrate": "bun run --env-file ../../.env src/db/migrate.ts",
    "db:reset": "bun run --env-file ../../.env src/db/reset.ts",
    "db:seed": "bun run --env-file ../../.env src/db/seed.ts",
    "db:studio": "bun run --env-file ../../.env drizzle-kit studio",
    "test": "bun test --env-file .env.test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "@presto/shared": "workspace:*",
    "@react-pdf/renderer": "^4.3.2",
    "consola": "^3.4.2",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.9",
    "hono-rate-limiter": "^0.5.3",
    "nanoid": "^5.1.7",
    "pg": "^8.20.0",
    "react": "^19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.2"
  }
}
